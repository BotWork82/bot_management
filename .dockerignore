# Fichiers Docker
Dockerfile
.dockerignore

# Dépendances (Docker doit installer les siennes, pas copier les tiennes)
node_modules
npm-debug.log
yarn-debug.log
yarn-error.log
pnpm-debug.log
.pnpm-store

# Dossiers de build Next.js (On veut un build propre dans le conteneur)
.next
out
build
dist

# Fichiers d'environnement (Sécurité : on ne copie pas les secrets locaux)
# .env
# .env.local
# .env.development.local
# .env.test.local
# .env.production.local
